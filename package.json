{
  "name": "doosilpay-api",
  "version": "0.0.0",
  "private": true,
  "description": "DooPay 백엔드 API (Express + TypeScript + Firebase)",
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "tsx watch --env-file=.env.development src/server.ts",
    "seed:health": "tsx --env-file=.env.development scripts/seed-health.ts",
    "create:owner": "tsx --env-file=.env.development scripts/create-owner.ts",
    "build": "tsc",
    "build:vercel": "node scripts/build-vercel.mjs",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5",
    "firebase-admin": "^13",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
